        "import pandas as pd\n",
        "from great_tables import GT\n",
        "import ast\n",
        "\n",
        "\n",
        "def dict_to_markdown_list(d):\n",
        "    return \"\\n\".join(f\"- **{k}**: {v}\" for k, v in d.items())\n",
        "\n",
        "\n",
        "perf_trees = pd.read_csv(\"../reports/tables/performance_trees.csv\", nrows=1)\n",
        "perf_trees['Meilleurs Paramètres'] = perf_trees['Meilleurs Paramètres'].apply(ast.literal_eval)\n",
        "\n",
        "perf_trees[\"Meilleurs Paramètres\"] = dict_to_markdown_list(perf_trees[\"Meilleurs Paramètres\"])\n",
        "\n",
        "(\n",
        "       GT(perf_trees)\n",
        "       .fmt_number(columns=[\"RMSE Train\", \"RMSE Test\"], locale = \"fr\", decimals=4)\n",
        "      .fmt_markdown(\"Meilleurs Paramètres\")\n",
        ")\n",
